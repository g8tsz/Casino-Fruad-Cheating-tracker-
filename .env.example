# Data source: memory | api
# - memory: in-app store (default)
# - api: push alerts/ingest to your backend (set LIVE_API_BASE_URL)
DATA_SOURCE=memory

# Optional: your backend base URL (must expose POST /api/fraud/alerts and POST /api/fraud/ingest)
# LIVE_API_BASE_URL=https://your-api.example.com
# LIVE_API_KEY=your-secret-key

# Optional: require Bearer or X-API-Key for POST /api/ingest
# INGEST_API_KEY=your-secret

# Detection thresholds (optional)
# RTP_MIN_PCT=85
# RTP_MAX_PCT=102
# BAD_REQUEST_RATE_THRESHOLD=0.15
# WIN_RATE_SUSPICIOUS_PCT=65
# RATE_ABUSE_PER_MIN=120
# ALERT_COOLDOWN_MS=600000
