# Data source: memory | api
DATA_SOURCE=memory

# Optional: backend base URL when DATA_SOURCE=api
# LIVE_API_BASE_URL=https://your-api.example.com
# LIVE_API_KEY=your-secret-key

# Ingest: auth, rate limit, webhook
# INGEST_API_KEY=your-secret
# INGEST_RATE_LIMIT_PER_MIN=120
# WEBHOOK_URL=https://your-webhook.example.com/alerts

# Threshold preset: strict | normal | lenient (default normal)
# THRESHOLD_PRESET=normal

# Detection thresholds (optional; overrides preset)
# RTP_MIN_PCT=85
# RTP_MAX_PCT=102
# WIN_RATE_SUSPICIOUS_PCT=65
# RATE_ABUSE_PER_MIN=120
# ALERT_COOLDOWN_MS=600000
# REPEATED_BET_COUNT_THRESHOLD=8
# SESSION_LENGTH_MAX_HOURS=8
# PLAYERS_PER_IP_THRESHOLD=5
# PLAYERS_PER_DEVICE_THRESHOLD=3

# Retention (days)
# EVENTS_RETENTION_DAYS=7
# ALERTS_RETENTION_DAYS=30
